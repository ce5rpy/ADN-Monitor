# ADN Monitor configuration (YAML)
# Config is read only at startup; changes take effect after restarting the monitor.

# ------------------------------------------------------------------------------
# GLOBAL
# ------------------------------------------------------------------------------
GLOBAL:
  # Display Bridge status
  BRIDGES_INC: false
  # Display Homebrew Peers status
  HOMEBREW_INC: true
  # Display lastheard table on main page
  LASTHEARD_INC: true
  LASTHEARD_ROWS: 20
  # Display empty masters in status
  EMPTY_MASTERS: false
  # Display TG Count on tgcount page
  TGCOUNT_INC: true
  TGCOUNT_ROWS: 20
  # IANA timezone (e.g. America/Santiago). last_heard/lstheard_log: stored UTC, shown in TIMEZONE.
  # TG Count daily bucket uses the calendar day in TIMEZONE when set; otherwise UTC.
  # TIMEZONE: "America/Santiago"

# ------------------------------------------------------------------------------
# SELF_SERVICE – Database credentials (MySQL) and password hash (must match hotspot_proxy_self_service.py)
# ------------------------------------------------------------------------------
SELF_SERVICE:
  USE_SELFSERVICE: true
  DB_SERVER: localhost
  DB_USERNAME: self_service_user
  DB_PASSWORD: your-password
  DB_NAME: self_service
  DB_PORT: 3306
  # Password hash: same salt/iterations as hotspot_proxy_self_service.py
  PBKDF2_SALT: "ADN"
  PBKDF2_ITERATIONS: 2000

# ------------------------------------------------------------------------------
# ADN_CONNECTION
# ------------------------------------------------------------------------------
ADN_CONNECTION:
  # ADN server's IP Address
  ADN_IP: "127.0.0.1"
  # ADN server's TCP reporting socket
  ADN_PORT: 4321
  # ms to wait for HELLO (opcode 0xFF) before assuming legacy (no extra TCP opcodes; same as classic FDMR)
  HELLO_TIMEOUT_MS: 1500

# ------------------------------------------------------------------------------
# OPB_FILTER
# Generally you don't need to use this but if you don't want to show in lastheard
# received traffic from OBP link put NETWORK ID e.g. 260210, 260211, 260212
# ------------------------------------------------------------------------------
OPB_FILTER:
  OPB_FILTER: ""

# ------------------------------------------------------------------------------
# ALIASES – ADN Systems https://github.com/Amateur-Digital-Network/ADN-DMR-Peer-Server
# ------------------------------------------------------------------------------
ALIASES:
  # Directory for alias JSON/CSV files (downloaded and local). Relative to monitor root.
  PATH: "./json"
  PEER_FILE: peer_ids.json
  SUBSCRIBER_FILE: subscriber_ids.json
  TGID_FILE: talkgroup_ids.json
  PEER_URL: "https://servers.adn.systems/peer_ids.json"
  SUBSCRIBER_URL: "https://servers.adn.systems/subscriber_ids.json"
  TGID_URL: "https://servers.adn.systems/talkgroup_ids.json"
  SERVER_ID_URL: "https://servers.adn.systems/server_ids.tsv"
  LOCAL_SUBSCRIBER_FILE: local_subscriber_ids.json
  # If file is older than STALE_HOURS or missing, download and verify checksum.
  # REVIEW_INTERVAL_MINUTES = how often to check (if missing, re-download). Defaults: 24 h, 5 min.
  STALE_HOURS: 24
  REVIEW_INTERVAL_MINUTES: 5
  CHECKSUM_URL: "https://servers.adn.systems/file_checksums.json"
  CHECKSUM_FILE: file_checksums.json
  # TG List and Bridge List pages (backend proxy for frontend)
  TG_LIST_URL: "https://servers.adn.systems/talkgroup_ids.json"
  BRIDGE_LIST_URL: "https://servers.adn.systems/server_ids.tsv"

# ------------------------------------------------------------------------------
# LOGGER
# ------------------------------------------------------------------------------
LOGGER:
  # ENABLED: false   # omit or true = normal; false = no console/file logs
  LOG_PATH: "./log"
  LOG_FILE: adn-monitor.log
  LOG_LEVEL: INFO

# ------------------------------------------------------------------------------
# MONITOR_APP — unified FastAPI (REST + WebSocket + report ingest)
# Run: python monitor.py
# ------------------------------------------------------------------------------
MONITOR_APP:
  LISTEN_HOST: ""
  LISTEN_PORT: 8080
  # REST /api/* and WebSocket /ws share LISTEN_HOST:LISTEN_PORT (no separate WS port).
  # Seconds between periodic full resync (last_heard, lstheard_log, slim ctable); live updates are event-driven.
  FREQUENCY: 1
  # Drop idle WebSocket clients after N seconds (0 = disable; legacy monitor.py only).
  CLIENT_TIMEOUT: 0
  # Report ingest — pick ONE (mutually exclusive; never tcp + mqtt together):
  #   tcp  — connect to adn-server REPORTS.REPORT_PORT (ADN_CONNECTION below)
  #   mqtt — subscribe to broker topics (server REPORTS.MQTT.ENABLED); no TCP report
  INGEST: tcp
  # Required only when INGEST: mqtt (must match adn-server REPORTS.MQTT)
  # MQTT:
  #   URL: "mqtt://127.0.0.1:1883"
  #   TOPIC_PREFIX: "adn/7302"
  #   QOS: 0
  # CORS_ORIGINS: "http://localhost:5173,https://dashboard.example.com"
  # Comma-separated IPs allowed to send X-Real-IP / X-Forwarded-For (login-by-ip behind nginx).
  # Default when omitted: 127.0.0.1, ::1 — set if the reverse proxy is on another host.
  # TRUSTED_PROXY_IPS: "127.0.0.1,::1,10.0.0.5"

# ------------------------------------------------------------------------------
# DASHBOARD
# ------------------------------------------------------------------------------
DASHBOARD:
  # Dashboard Title (header); e.g. "ADN Systems Dashboard" or "ADN Systems Chile"
  DASHTITLE: "ADN Systems"
  # Background image True or False; if True put a bk.jpg 1920x1080 in img folder
  BACKGROUND: false
  # Default language: en, es, fr, pt, it, nl, de
  LANGUAGE: "en"

  # Self-service (local): show/hide the "Self-service" nav item (local server).
  SELF_SERVICE: true

  # Console: show Console page in Info menu (call start/end messages). Set to true to enable.
  SHOW_CONSOLE: false

  # JSON feed for /serverstatus (network server list). Proxied at GET /api/servers/status.
  # Default if omitted: https://adn.systems/servers/status.json
  # SERVER_STATUS_URL: "https://adn.systems/servers/status.json"

  # Minimum call duration (seconds) for dashboard table only (Last Heard page always shows all)
  MIN_DURATION: 3

  # Navbar links: optional label + list of { name, url }. Add as many items as you need.
  nav_links:
    name: "Links"
    items:
      - name: "ADN Systems"
        url: "https://adn.systems"
      - name: "ADN Live"
        url: "https://listen.adn.systems/"

  # Footer links: same structure as nav_links — list of { name, url }
  footer:
    items:
      # - name: "SYSOP"
      #   url: "mailto:user@example.com"
      # - name: "SYSOP 2"
      #   url: "https://qrz.com/db/N0CALL"
      # - name: "ADN"
      #   url: "https://adn.systems"

  # News/events marquee (below logo). Same structure as footer — list of { name, url } (url optional).
  news:
    items:
      # - name: "Scheduled maintenance Sunday 10:00–12:00 UTC"
      # - name: "New reflector"
      #   url: "https://adn.systems"
