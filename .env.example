# ADN Monitor — single env file (project root)
#   cp .env.example .env
#
# Used by:
#   - monitor.py / db_bootstrap.py (auto-load on start)
#   - monitor/run.sh, start.sh, systemd (EnvironmentFile)
#   - Vite (npm run dev / npm run build) — only VITE_* below
#
# Alias URLs, DB, ingest: adn-monitor.yaml (not here).

# Path to monitor YAML (required in production)
ADN_CONFIG_PATH=/opt/adn-monitor/monitor/adn-monitor.yaml

# Hotspot proxy: configure PROXY in adn-server.yaml (not in this repo).

# Optional FastAPI session signing (default: PBKDF2_SALT from YAML)
# MONITOR_SESSION_SECRET=

# --- Frontend build (Vite) — production: leave VITE_API_BASE empty (same origin via Nginx) ---
VITE_API_BASE=
VITE_DEFAULT_LANGUAGE=en
