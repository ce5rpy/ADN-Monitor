# ADN Monitor – centralised env (backend, frontend build, monitor)
# Copy to .env in the project root and adjust. Root is used first; backend/ and
# frontend/ can have their own .env as fallback when root .env is missing.
#
# Load order:
#   - Backend (PHP):  root/.env  →  backend/.env (fallback)
#   - Frontend (Vite): root/.env  →  frontend/.env (fallback)
#   - Monitor: run.sh and systemd use root .env when present (see README).

# -----------------------------------------------------------------------------
# Backend (PHP), Monitor (Python) and Hotspot Proxy: path to main config file
# -----------------------------------------------------------------------------
ADN_CONFIG_PATH=/opt/adn-monitor/monitor/adn-mon.yaml

# Base URL for alias/files when [ALIASES] in YAML does not define URLs (backend API)
ALIASES_BASE_URL=https://adn.systems/files

# Slim base path when API is under a subpath (e.g. /api). Empty = routes at root.
# API_BASE_PATH=

# -----------------------------------------------------------------------------
# Frontend (Vite): only read at build time (npm run build / npm run dev)
# -----------------------------------------------------------------------------
# API base URL (empty = same origin). E.g. '' or 'https://chile.adn.systems'
VITE_API_BASE=

# Base URL for alias lists when API does not serve them
VITE_ALIASES_BASE_URL=https://adn.systems/files

# Default language when user has no preference and browser language is not used
VITE_DEFAULT_LANGUAGE=en
