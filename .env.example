# ADN Monitor – config centralizado (backend + frontend build)
# Copia a .env en la raíz del proyecto y ajusta.
# - Backend (PHP): carga este .env automáticamente desde la raíz.
# - Frontend (Vite): lee VITE_* al hacer npm run build (envDir apunta a la raíz).
# - Monitor (Python): usa ADN_CONFIG_PATH si está exportada (ej. systemd Environment).

# -----------------------------------------------------------------------------
# Backend (PHP) y Monitor (Python): ruta al config principal
# -----------------------------------------------------------------------------
ADN_CONFIG_PATH=/opt/adn-monitor/monitor/adn-mon.yaml

# Base URL para alias/archivos cuando [ALIASES] no define URLs (backend API)
ALIASES_BASE_URL=https://adn.systems/files

# -----------------------------------------------------------------------------
# Frontend (Vite): solo se leen en tiempo de build (npm run build)
# -----------------------------------------------------------------------------
# Base URL de la API (vacío = mismo origen). Ej: '' o 'https://chile.adn.systems'
VITE_API_BASE=

# Base URL para listas/alias cuando la API no devuelve aliases
VITE_ALIASES_BASE_URL=https://adn.systems/files

# Idioma por defecto si no hay preferencia ni idioma del navegador
VITE_DEFAULT_LANGUAGE=en
