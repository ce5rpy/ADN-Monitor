# Frontend (Vite) – env example (fallback when root .env is missing)
# Copy to .env here. Used only if there is no .env in the project root.
# Prefer a single .env at project root (see root .env.example) for backend + frontend + monitor.
# Variables are read at build time (npm run build / npm run dev).

# API base URL (empty = same origin). E.g. '' or 'https://chile.adn.systems'
VITE_API_BASE=

# Base URL for alias lists when API does not serve them
VITE_ALIASES_BASE_URL=https://adn.systems/files

# Default language when user has no preference and browser language is not used
VITE_DEFAULT_LANGUAGE=en
