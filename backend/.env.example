# Backend API – env example (fallback when root .env is missing)
# Copy to .env here. Used only if there is no .env in the project root.
# Prefer a single .env at project root (see root .env.example) for backend + frontend + monitor.

# Path to the monitor config file (YAML; DASHBOARD section → title, language, etc.)
ADN_CONFIG_PATH=/opt/adn-monitor/monitor/adn-mon.yaml

# Base URL for alias/files when ALIASES section does not define URLs
# ALIASES_BASE_URL=https://adn.systems/files

# Slim base path when API is under a subpath (e.g. /api). Empty = routes at root.
# API_BASE_PATH=
