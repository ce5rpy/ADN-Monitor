# -----------------------------------------------------------------------------
# ADN Monitor – ignore configs, envs, deps, build and IDE/OS junk
# -----------------------------------------------------------------------------

# Env and secrets (keep .env.example)
.env
.env.local
.env.*.local
!.env.example
frontend/.env
!frontend/.env.example

# Local/config overrides (keep examples)
*.local
*.local.yaml
*.local.yml
monitor/adn-monitor.yaml

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual envs
.venv/
venv/
env/
ENV/
.env/
pyenv/
.python-version

# -----------------------------------------------------------------------------
# Build / output
# -----------------------------------------------------------------------------
frontend/dist/
*.tsbuildinfo
*.local

# -----------------------------------------------------------------------------
# Logs and runtime
# -----------------------------------------------------------------------------
*.log
log/
monitor/log/
tmp/
temp/
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# IDE and OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# JSON data (directory kept via .gitkeep)
# -----------------------------------------------------------------------------
monitor/json/*.json

# -----------------------------------------------------------------------------
# Local ops scripts (deployment-specific; not shipped in repo)
# -----------------------------------------------------------------------------
scripts/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
docs-priv/
*.bak
*.backup
*.orig

# Brand asset: tracked in repo for fresh clones; listed here so local edits are not
# staged by mistake. After customizing, run:
#   git update-index --skip-worktree frontend/public/img/logo.png
logo.png
frontend/public/img/logo.png
